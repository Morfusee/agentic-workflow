{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {},
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 60000,
        "timeout": 120000,
      },
    },
  },
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": true,
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true,
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
    },
    "codebase-memory": {
      "type": "local",
      "command": ["codebase-memory-mcp"],
    },
  },
  "permission": {
    "external_directory": {
      "$HOME/Documents/Programming/**": "allow",
    },
    "edit": {
      "$HOME/Documents/Programming/**": "allow",
    },
    "read": {
      "$HOME/Documents/Programming/**": "allow",
      "$HOME/.ssh/**": "deny",
      "$HOME/.aws/**": "deny",
      "$HOME/AppData/**": "deny",
      "./.env": "deny",
      "./.env.*": "deny",
      "./secrets/**": "deny",
    },
    "bash": {
      "*": "allow",
      "npx *": "deny",
      "node -e *": "deny",
      "node --eval *": "deny",
      "choco *": "deny",
      "winget *": "deny",
      "npm install -g *": "deny",
      "pnpm add -g *": "deny",
      "reg *": "deny",
      "netsh *": "deny",
      "sc *": "deny",
      "schtasks *": "deny",
      "shutdown *": "deny",
      "taskkill /f *": "deny",
      "node *": "ask",
      "python *": "ask",
      "git push *": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "rm -rf *": "ask",
      "del /s /q *": "ask",
      "rmdir /s /q *": "ask",
    },
  },
}
