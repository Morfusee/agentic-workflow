{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {},
  "plugin": [
    "$HOME/Documents/Programming/ponytail/.opencode/plugins/ponytail.mjs",
  ],
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "enabled": true,
    },
    "clickup": {
      "type": "remote",
      "url": "https://mcp.clickup.com/mcp",
      "enabled": true,
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true,
    },
  },
  "permission": {
    "external_directory": {
      "C:/Users/*/Documents/Programming/**": "allow",
    },
    "edit": {
      "C:/Users/*/Documents/Programming/**": "allow",
    },
    "read": {
      "C:/Users/*/Documents/Programming/**": "allow",
      "C:/Users/*/.ssh/**": "deny",
      "C:/Users/*/.aws/**": "deny",
      "C:/Users/*/AppData/**": "deny",
      "./.env": "deny",
      "./.env.*": "deny",
      "./secrets/**": "deny",
    },
    "bash": {
      "*": "allow",
      "npx *": "deny",
      "node -e *": "deny",
      "node --eval *": "deny",
      "choco *": "deny",
      "winget *": "deny",
      "npm install -g *": "deny",
      "pnpm add -g *": "deny",
      "reg *": "deny",
      "netsh *": "deny",
      "sc *": "deny",
      "schtasks *": "deny",
      "shutdown *": "deny",
      "taskkill /f *": "deny",
      "node *": "ask",
      "python *": "ask",
      "git push *": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "rm -rf *": "ask",
      "del /s /q *": "ask",
      "rmdir /s /q *": "ask",
    },
  },
}
