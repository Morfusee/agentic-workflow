{
  "default_domain": "personal_tasks",
  "domains": {
    "personal_tasks": {
      "kind": "lightweight_task",
      "name": "Personal Tasks",
      "triggers": [
        "personal task",
        "personal reminder",
        "errand",
        "habit",
        "goal",
        "non-school task"
      ],
      "template": "personal_task_four_section",
