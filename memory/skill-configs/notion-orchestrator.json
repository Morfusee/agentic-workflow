      },
      "defaults": {
        "status": "Not Started"
      },
      "allowed_statuses": ["Not Started", "In Progress", "Done", "Archived"],
      "allowed_priorities": ["Low", "Medium", "High"],
      "allowed_tags": ["Feature", "Fix", "Refactor", "Release"],
      "tag_mapping": {
        "bug": "Fix",
        "fix": "Fix",
        "feature": "Feature",
        "enhancement": "Feature",
        "refactor": "Refactor",
        "release": "Release"
      }
    }
